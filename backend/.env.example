APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Real-time GPS: set to "pusher" on Hostinger (required for instant maps).
# "log" = events only written to laravel.log (NO live WebSocket).
# "reverb" = local/VPS only (needs `php artisan reverb:start`).
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Hosted Pusher (Hostinger shared hosting) — fill these, then set BROADCAST_CONNECTION=pusher
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=ap1

# Laravel Reverb (local / VPS only — needs `php artisan reverb:start`)
REVERB_APP_ID=deliverex
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=6001
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=6001

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@deliverexapp.com"
MAIL_FROM_NAME="Deliverex"
MAIL_ACCOUNTS_ADDRESS="accounts@deliverexapp.com"
MAIL_SUPPORT_ADDRESS="deliverexapp@gmail.com"
MAIL_SUPPORT_FROM="noreply@deliverexapp.com"
MAIL_QUEUE=false
INQUIRY_ADMIN_PATH="/admin/inquiries"
RESEND_API_KEY=

FRONTEND_URL=http://localhost:5173

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Origins allowed to call the API from a browser (Vite defaults to port 5173).
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Full path to tesseract.exe if PATH is not visible to PHP (restart artisan serve after setting)
# Use forward slashes on Windows, e.g.:
# TESSERACT_PATH="C:/Program Files/Tesseract-OCR/tesseract.exe"

# OCR engine: local uses TESSERACT_PATH/PATH; remote calls an HTTP OCR service.
# Primary OCR provider: document_ai (Google) or local.
OCR_PROVIDER=document_ai
OCR_ENGINE=local
# OCR_REMOTE_URL=https://your-render-service.onrender.com/ocr
# OCR_REMOTE_TOKEN=
# OCR_REMOTE_TIMEOUT=180
# OCR_REMOTE_PSM_CANDIDATES=3,4,6,11,12
# OCR_REMOTE_MAX_VARIANTS=4
# OCR_REMOTE_ENABLE_DESKEW=true
# OCR_REMOTE_ENABLE_MORPH=true
# OCR_DIAGNOSTICS_ENABLED=true
# OCR_DEBUG_MODE=true

# Google Document AI (Expense Parser)
# GOOGLE_APPLICATION_CREDENTIALS=storage/app/google/document-ai.json
# GOOGLE_CLOUD_PROJECT=receiptocr-500719
# DOCUMENT_AI_LOCATION=us
# DOCUMENT_AI_PROCESSOR_ID=8f2aed350e5c227a
# DOCUMENT_AI_TIMEOUT=30
# DOCUMENT_AI_TRANSPORT=rest
# DOCUMENT_AI_RETRIES=1
# DOCUMENT_AI_DECRYPT_KEY=

# Process OCR immediately after upload — no queue worker required (recommended for defense)
OCR_SYNC_MODE=true

# When false, OCR is queued — requires: php artisan queue:work
# OCR_SYNC_MODE=false

# Optional local-only stub when Tesseract is missing (never enable in production)
# OCR_STUB_FALLBACK=false

# JWT session management (FR 1.12–1.21)
JWT_SECRET=
JWT_ACCESS_TTL_MINUTES=120
JWT_REFRESH_TTL_DRIVER_MINUTES=10080
JWT_REFRESH_TTL_CUSTOMER_MINUTES=43200
JWT_REFRESH_TTL_STAFF_MINUTES=1440
SESSION_REFRESH_COOKIE=deliverex_refresh
SESSION_SECURE_COOKIE=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://deliverexapp.com

# Philippine Standard Geographic Code reference directory.
PSGC_API_URL=https://psgc.cloud/api/v2
PSGC_API_TIMEOUT=12
PSGC_CACHE_TTL=604800

# OpenRouteService — road routing only (geocoding uses Google Maps)
OPENROUTESERVICE_API_KEY=
# OPENROUTESERVICE_URL=https://api.openrouteservice.org/v2/directions/driving-car

# Google Maps Platform — address autocomplete, geocoding, and reverse geocoding
GOOGLE_MAPS_API_KEY=

# Enables concise application-log stages. Full requests/responses/candidates are
# always retained in geocoding_traces for the confirmed-location audit pipeline.
GPS_DEBUG_PIPELINE=false

# Near-realtime GPS ingest (native/PWA ~15s pings). Window/movement 0 = store every ping.
GPS_MIN_MOVEMENT_METERS=0
GPS_DUPLICATE_RADIUS_METERS=5
GPS_DUPLICATE_WINDOW_SECONDS=0
GPS_HEARTBEAT_SECONDS=0
GPS_POLL_INTERVAL_SECONDS=5
GPS_INTERVAL_MOVING_SECONDS=15
GPS_INTERVAL_STOPPED_SECONDS=15
